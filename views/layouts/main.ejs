                    <li><a href="/subjects/new">Add Subject</a></li>
                </ul>
            </td>
            <td width="80%" height="400" valign="top" class="contant">
                <h2>Welcome to the Student Management System</h2>
                <%- body %>
            </td>
        </tr>
        <tr class="footer" width="100%">
            <td colspan="2" height="50" align="center">
                <h3>Footer</h3>
            </td>
        </tr>
    </table>

