<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>Student Details </h1>
    <hr>
    <table>
        <tr>
            <th>ID</th>
            <th>Admission Number</th>
            <th>First Name</th>
            <th>Last Name</th>
        </tr>

        <tr>
            <td>
                <%= student.id %>
