
    <h1>All Students</h1>

    <table>

        <tr>
            <th>ID</th>
            <th>admission_number</th>
            <th>first_name</th>
            <th>last_name</th>
            <th>Action</th>
        </tr>

        <% students.forEach(student=> { %>

            <tr>

                <td>
                    <%= student.id %>
                </td>
                <td>
                    <%= student.admission_number %>
                </td>
                <td>
                    <%= student.first_name %>
                </td>
                <td>
                    <%= student.last_name %>
                </td>
                <td>
                    <a href="/students/<%= student.id %>">
                        show
                    </a>
                </td>

            </tr>

            <% }) %>

    </table>
